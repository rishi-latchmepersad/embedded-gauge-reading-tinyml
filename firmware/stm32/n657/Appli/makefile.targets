# ---------------------------------------------------------------------------
# Tip-focus geometry heatmap model wrapper
# (tip_focus_v4_112_int8, LL_ATON NPU runtime).
# ---------------------------------------------------------------------------
#
# The generated network.c is #included directly into the wrapper translation
# unit.  The NPU runtime manages all activations and weights intenally in
# AXISRAM and xSPI2 regions.  The pre-flashed weight blob is provided by
# the export as network_atonbuf.xSPI2.raw.
#
# Build-time control flags (tip-focus is debug-only for prod v0.8; keep it OFF
# by default. Boot dry-run remains OFF). Override from the make invocation:
#   make APP_AI_ENABLE_TIP_FOCUS_GEOMETRY_STAGE=1
#   make APP_AI_ENABLE_TIP_FOCUS_BOOT_DRY_RUN=1
APP_AI_ENABLE_TIP_FOCUS_GEOMETRY_STAGE ?= 0
APP_AI_ENABLE_TIP_FOCUS_BOOT_DRY_RUN ?= 0
APP_AI_ENABLE_INNER_CELSIUS_MASK ?= 0

./Src/ai_network_tip_focus_v4_112_int8.o: ../Src/ai_network_tip_focus_v4_112_int8.c
	arm-none-eabi-gcc "$<" -mcpu=cortex-m55 -std=gnu11 -g3 -DDEBUG -DUSE_HAL_DRIVER -DSTM32N657xx -DUSE_NUCLEO_64 -DTX_INCLUDE_USER_DEFINE_FILE -DTX_SINGLE_MODE_SECURE=1 -DFX_INCLUDE_USER_DEFINE_FILE -DAPP_HAS_PARALLEL_NETWORKS=0 -DLL_ATON_PLATFORM=LL_ATON_PLAT_STM32N6 -DLL_ATON_OSAL=LL_ATON_OSAL_THREADX -c -I../Inc -I../../Secure_nsclib -I../../Drivers/STM32N6xx_HAL_Driver/Inc -I../../Drivers/CMSIS/Device/ST/STM32N6xx/Include -I../../Drivers/STM32N6xx_HAL_Driver/Inc/Legacy -I../../Drivers/BSP/STM32N6xx_Nucleo -I../../Drivers/CMSIS/Include -I../../Middlewares/ST/threadx/common/inc -I../../Middlewares/ST/threadx/ports/cortex_m55/gnu/inc -I../../Middlewares/ST/filex/common/inc -I../../Middlewares/ST/filex/ports/generic/inc -DAPP_AI_ENABLE_TIP_FOCUS_GEOMETRY_STAGE=$(APP_AI_ENABLE_TIP_FOCUS_GEOMETRY_STAGE) -DAPP_AI_ENABLE_TIP_FOCUS_BOOT_DRY_RUN=$(APP_AI_ENABLE_TIP_FOCUS_BOOT_DRY_RUN) -I../../st_ai_output/packages/tip_focus_v4_112_int8_n6_npu/st_ai_output -IC:/Users/rishi_latchmepersad/STM32Cube/Repository/Packs/STMicroelectronics/X-CUBE-AI/10.2.0/Middlewares/ST/AI/Npu/ll_aton -IC:/Users/rishi_latchmepersad/STM32Cube/Repository/Packs/STMicroelectronics/X-CUBE-AI/10.2.0/Middlewares/ST/AI/Npu/Devices/STM32N6XX -Os -ffunction-sections -fdata-sections -Wall -fstack-usage -fcyclomatic-complexity -mcmse -MMD -MP -MF"Src/ai_network_tip_focus_v4_112_int8.d" -MT"./Src/ai_network_tip_focus_v4_112_int8.o" --specs=nano.specs -mfpu=fpv5-d16 -mfloat-abi=hard -mthumb -o "$@"

# Application files that need the tip-focus compile-time flags so their
