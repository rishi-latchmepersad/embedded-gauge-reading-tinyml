# Codex and STM32CubeIDE workspace noise.
/.metadata/
/firmware/stm32/.project
/firmware/stm32/n657/.metadata/

# Generated firmware and host build outputs.
/firmware/stm32/n657/Appli/.metadata/
/firmware/stm32/n657/Appli/Debug/
/firmware/stm32/n657/Appli/Lib/
/firmware/stm32/n657/Appli/Makefile
/firmware/stm32/n657/Appli/Src/*.d
/firmware/stm32/n657/Appli/Src/*.o
/firmware/stm32/n657/Appli/Src/*.su
/firmware/stm32/n657/Appli/Src/*.cyclo
/firmware/stm32/n657/FSBL/Debug/
/firmware/stm32/n657/FSBL/ai_fsbl.hex
/firmware/stm32/n657/host_tests/build/
/firmware/stm32/n657/n657_Appli/
/firmware/stm32/n657/st_ai_output/*.raw
/firmware/stm32/n657/st_ai_output/*.json
/firmware/stm32/n657/st_ai_output/README.md
/firmware/stm32/n657/st_ai_output/packages/
/tmp/
/opencode.jsonc
/docs/int8_drift_decision_report.md
/docs/phase-13a-tip-focus-firmware-integration-spike.md

# Local ML training artifacts, caches, and downloaded binaries.
/ml/artifacts/
/ml/debug/
/ml/runs/
/ml/tmp/
/ml/c/*.so
/ml/*.pt
/ml/*.npy
**/__pycache__/
*.py[cod]

# Local firmware/export artifacts and vendor checkout.
/n657_Appli.map
/nul
/tmp_repack_err.log
/st_ai_output/
/third_party_refs/

# Local-only third-party dataset; retain the source archive locally but do not
# commit or redistribute the downloaded images and annotations.
/ml/data/Gauge-Meter-Detection-v2.v7i.yolov8-obb.zip*
/ml/data/external/gauge_meter_detection_v2_yolov8_obb/

# Locally materialized training datasets. Keep source labels, raw captures,
# manifests, and input archives visible; these copies are reproducible from
# the preparation scripts and otherwise add tens of thousands of Git scans.
/ml/data/gauge_center_tip_v1_160_gray/
/ml/data/gauge_center_tip_v1_224_gray/
/ml/data/gauge_face_ellipse_v1/
/ml/data/gauge_face_ellipse_v1_640_gray/
/ml/data/initial_temp_gauge_v1/

# Large local train/validation/test archives are generated dataset bundles;
# keep the preparation scripts and labelled source archives under version
# control without making Git scan or upload hundreds of megabytes of samples.
/ml/data/labelled/train_*.zip
/ml/data/labelled/test_*.zip
/ml/data/labelled/val_*.zip

# Windows download metadata should not become separate repository files.
**/*:Zone.Identifier
