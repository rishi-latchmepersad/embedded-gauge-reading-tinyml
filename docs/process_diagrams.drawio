<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/28.1.2 Chrome/138.0.7204.243 Electron/37.4.0 Safari/537.36" version="28.1.2" pages="2">
  <diagram id="6fHF2__YJ60N_B--ARtN" name="OBB_and_CNN_Process">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="2400" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="cnn_title_why" value="Why each step is performed" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontStyle=1;fontSize=16;" parent="1" vertex="1">
          <mxGeometry y="680" width="360" height="30" as="geometry" />
        </mxCell>
        <mxCell id="cnn_tech_1" value="The IMX335 image sensor captures a frame (in the format of YUV422 224×224 px)&lt;br&gt;- Manual exposure used (AEC disabled)&lt;br&gt;- The brightness is seeded from last accepted brightness value&lt;br&gt;  or 2/3-range fraction on first boot" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#dae8fc;strokeColor=#6c8ebf;image=process_diagrams_assets/cnn_01_capture.svg;imageAlign=right;imageVerticalAlign=middle;imageWidth=48;imageHeight=48;spacingRight=58;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="40" y="90" width="270" height="170" as="geometry" />
        </mxCell>
        <mxCell id="cnn_tech_2" value="A brightness gate is applied. We measure mean/min/max luma&lt;br&gt;  over the full training crop (155×123 px)&lt;br&gt;We reject if the mean &amp;lt; 100 (too dark)&lt;br&gt;  or the mean ≥ 200 &amp;amp; min ≥ 20 (too bright)&lt;br&gt;&lt;br&gt;&lt;div&gt;We nudge exposure ×2 or ÷2, and retry&lt;br&gt;  up to 16 attempts&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;image=process_diagrams_assets/cnn_02_brightness.svg;imageAlign=right;imageVerticalAlign=middle;imageWidth=48;imageHeight=48;spacingRight=58;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="350" y="90" width="280" height="170" as="geometry" />
        </mxCell>
        <mxCell id="cnn_tech_3" value="An OBB localizer is then applied (based on MobileNetv2, ~166 layers)&lt;br&gt;- Input: full 224x224 YUV422 frame&lt;br&gt;- Output: oriented box (cx, cy, w, h, cos, sin) for dial-face localization" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;image=process_diagrams_assets/cnn_03_obb_localizer.svg;imageAlign=right;imageVerticalAlign=middle;imageWidth=48;imageHeight=48;spacingRight=58;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="670" y="90" width="300" height="170" as="geometry" />
        </mxCell>
        <mxCell id="cnn_tech_4" value="OBB crop selection is then performed&lt;br&gt;- Validate OBB box&lt;br&gt;  (min size, angle, in-bounds)&lt;br&gt;- Scale by 1.20 and clamp to frame&lt;br&gt;- Fall back to fixed training crop&lt;br&gt;  x=23 y=57 w=155 h=123 if invalid" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#fff2cc;strokeColor=#d6b656;image=process_diagrams_assets/cnn_04_crop_selection.svg;imageAlign=right;imageVerticalAlign=middle;imageWidth=48;imageHeight=48;spacingRight=58;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1010" y="90" width="290" height="170" as="geometry" />
        </mxCell>
        <mxCell id="cnn_tech_5" value="&amp;nbsp;The scalar CNN model is then utilized for inference (int8 CNN, based on MobileNetV2, ~189 layers)&lt;br&gt;- Input: crop region extracted from&lt;br&gt;  YUV422 buffer, resized + normalized&lt;br&gt;- Output: single float temperature estimate, with output calibration when enabled" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;image=process_diagrams_assets/cnn_05_scalar_stage.svg;imageAlign=right;imageVerticalAlign=middle;imageWidth=48;imageHeight=48;spacingRight=58;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1340" y="90" width="300" height="170" as="geometry" />
        </mxCell>
        <mxCell id="cnn_tech_6" value="Calibrated output&lt;br&gt;- Dequantize int8 → float32&lt;br&gt;- Log to SD card CSV&lt;br&gt;  (inference/YYYY-MM-DD.csv)&lt;br&gt;- Report via UART for quick debugging" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#e1d5e7;strokeColor=#9673a6;image=process_diagrams_assets/cnn_06_calibrated_output.svg;imageAlign=right;imageVerticalAlign=middle;imageWidth=48;imageHeight=48;spacingRight=58;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1680" y="90" width="280" height="170" as="geometry" />
        </mxCell>
        <mxCell id="cnn_why_1" value="Manual exposure gives consistent luma/brightness across captures.&amp;nbsp;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;AEC chases highlights (e.g. glare spots) and would destabilize the scalar model input&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Cached seed means no brightness search delay after the first capture.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="40" y="480" width="270" height="190" as="geometry" />
        </mxCell>
        <mxCell id="cnn_why_2" value="The scalar model was trained on well-exposed frames. Underexposed frames lose needle contrast, and overexposed frames blow out the dial face.&amp;nbsp;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Measuring the full crop avoids being fooled by a specular glare spot or reflection on the gauge face.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="350" y="480" width="280" height="190" as="geometry" />
        </mxCell>
        <mxCell id="cnn_why_3" value="The Oriented Bounding Box (OBB) localizer finds the gauge face (even if it&#39;s at an angle) before the scalar head reads it. This keeps the crop aligned to the dial at the orientation that the model was trained on." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="670" y="480" width="300" height="190" as="geometry" />
        </mxCell>
        <mxCell id="cnn_why_4" value="The OBB box used to crop out background pixels. It is checked for size and bounds, and the fixed training crop stays as a safe fallback when the detector collapses or wanders off-frame." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="1010" y="480" width="290" height="190" as="geometry" />
        </mxCell>
        <mxCell id="cnn_why_5" value="A large int8 CNN model was found to run efficiently on the NPU and retain good accuracy after quantization and calibration on the board.&amp;nbsp;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;The final head of this CNN is a 1-neuron Dense layer, used to predict the temperature estimate. A correction curve can be applied when enabled to trim residual edge bias from board deployment.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="1340" y="480" width="300" height="190" as="geometry" />
        </mxCell>
        <mxCell id="cnn_why_6" value="&lt;div&gt;The final calibrated temperature output is then dequantized and logged.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;Logging every inference to SD card enables offline accuracy analysis and retraining data collection without modifying firmware." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="1680" y="480" width="280" height="190" as="geometry" />
        </mxCell>
        <mxCell id="cnn_e1" style="endArrow=block;html=1;strokeColor=#000000;" parent="1" source="cnn_tech_1" target="cnn_tech_2" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cnn_e2" style="endArrow=block;html=1;strokeColor=#000000;" parent="1" source="cnn_tech_2" target="cnn_tech_3" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cnn_e3" style="endArrow=block;html=1;strokeColor=#000000;" parent="1" source="cnn_tech_3" target="cnn_tech_4" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cnn_e4" style="endArrow=block;html=1;strokeColor=#000000;" parent="1" source="cnn_tech_4" target="cnn_tech_5" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cnn_e5" style="endArrow=block;html=1;strokeColor=#000000;" parent="1" source="cnn_tech_5" target="cnn_tech_6" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cnn_w1" style="dashed=1;endArrow=none;html=1;strokeColor=#d79b00;" parent="1" source="zElmDHNvidVek9H3AHMp-1" target="cnn_why_1" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cnn_w2" style="dashed=1;endArrow=none;html=1;strokeColor=#d79b00;" parent="1" source="zElmDHNvidVek9H3AHMp-3" target="cnn_why_2" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cnn_w3" style="dashed=1;endArrow=none;html=1;strokeColor=#d79b00;" parent="1" source="zElmDHNvidVek9H3AHMp-5" target="cnn_why_3" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cnn_w4" style="dashed=1;endArrow=none;html=1;strokeColor=#d79b00;" parent="1" source="zElmDHNvidVek9H3AHMp-7" target="cnn_why_4" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cnn_w5" style="dashed=1;endArrow=none;html=1;strokeColor=#d79b00;" parent="1" source="zElmDHNvidVek9H3AHMp-9" target="cnn_why_5" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cnn_w6" style="dashed=1;endArrow=none;html=1;strokeColor=#d79b00;" parent="1" target="cnn_why_6" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1820" y="435.5" as="sourcePoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="zElmDHNvidVek9H3AHMp-2" value="" style="dashed=1;endArrow=none;html=1;strokeColor=#d79b00;" parent="1" source="cnn_tech_1" target="zElmDHNvidVek9H3AHMp-1" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="175" y="260" as="sourcePoint" />
