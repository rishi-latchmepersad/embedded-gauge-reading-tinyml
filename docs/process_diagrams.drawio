        <mxCell id="zElmDHNvidVek9H3AHMp-4" value="" style="dashed=1;endArrow=none;html=1;strokeColor=#d79b00;" parent="1" source="cnn_tech_2" target="zElmDHNvidVek9H3AHMp-3" edge="1">
