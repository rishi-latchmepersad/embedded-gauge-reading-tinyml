        <mxCell id="zElmDHNvidVek9H3AHMp-9" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;editableCssRules=.*;image=data:image/svg+xml,;" parent="1" vertex="1">
