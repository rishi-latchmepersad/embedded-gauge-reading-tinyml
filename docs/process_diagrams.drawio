  <diagram id="classicalCVBaseline01" name="Classical_CV_Baseline_Process">
    <mxGraphModel dx="964" dy="674" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="cv_title_tech" value="Classical Firmware Baseline Process" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontStyle=1;fontSize=16;" parent="1" vertex="1">
          <mxGeometry y="30" width="350" height="30" as="geometry" />
        </mxCell>
        <mxCell id="cv_tech_1" value="A 224x224 YUV422 preview-frame snapshot is copied from the capture buffer into SRAM. The firmware profiles mean luma and bright-pixel ratio first, then switches to a bright-relaxed threshold set when the frame is overexposed." style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;image=process_diagrams_assets/cv_01_yuv422_snapshot.svg;imageAlign=right;imageVerticalAlign=middle;imageWidth=48;imageHeight=48;spacingRight=58;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="40" y="90" width="240" height="200" as="geometry" />
        </mxCell>
        <mxCell id="cv_tech_2" value="Five center hypotheses are tested: bright centroid, fixed training crop, board prior, rim geometry, and the inner image center. All candidates stay inside the training crop and the bright centroid only wins if it survives the local polar vote." style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;image=process_diagrams_assets/cv_02_center_hypotheses.svg;imageAlign=right;imageVerticalAlign=middle;imageWidth=48;imageHeight=48;spacingRight=58;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="320" y="90" width="320" height="200" as="geometry" />
        </mxCell>
        <mxCell id="cv_tech_3" value="For each seed, the baseline votes over 360 polar bins to find a dark spoke. It rejects saturated pixels and the subdial mask, weights the middle shaft more heavily, checks radial and tangential alignment, boosts hub and tip continuity, and can rescue a hot-zone wrap-around peak near the sweep boundary." style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;image=process_diagrams_assets/cv_03_hough_votes.svg;imageAlign=right;imageVerticalAlign=middle;imageWidth=48;imageHeight=48;spacingRight=58;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="680" y="90" width="320" height="200" as="geometry" />
        </mxCell>
        <mxCell id="cv_tech_4" value="When the local geometry sweep is enabled, each accepted seed is refined over a small 5x5 offset grid and the best-quality estimate wins. The selector then compares source priority, peak quality, and consensus across all valid hypotheses." style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;image=process_diagrams_assets/cv_04_confidence_selection.svg;imageAlign=right;imageVerticalAlign=middle;imageWidth=48;imageHeight=48;spacingRight=58;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1030" y="90" width="320" height="200" as="geometry" />
        </mxCell>
        <mxCell id="cv_tech_5" value="A confidence and peak-separation gate must pass before publishing. Low-confidence, ambiguous, or off-center estimates are rejected, and the firmware can hold the last stable value or smooth the small history buffer across up to three frames." style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;image=process_diagrams_assets/cv_05_threshold_gate.svg;imageAlign=right;imageVerticalAlign=middle;imageWidth=48;imageHeight=48;spacingRight=58;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1390" y="90" width="300" height="200" as="geometry" />
        </mxCell>
        <mxCell id="cv_tech_6" value="The winning angle is converted to temperature with the calibrated sweep map. The firmware applies a small angle offset, clamps the sweep to 135°..405°, and maps 270° of sweep to -30°C to +50°C before logging the result." style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;image=process_diagrams_assets/cv_06_angle_to_temperature.svg;imageAlign=right;imageVerticalAlign=middle;imageWidth=48;imageHeight=48;spacingRight=58;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1730" y="90" width="290" height="200" as="geometry" />
        </mxCell>
        <mxCell id="cv_why_1" value="The baseline works directly on the raw YUV422 preview buffer so it stays cheap in memory and compute. Luma is enough for this detector, so color channels are ignored." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="40" y="480" width="240" height="220" as="geometry" />
        </mxCell>
        <mxCell id="cv_why_2" value="Using five hypotheses makes the baseline robust to glare, crop drift, and board framing changes. The bright centroid is helpful, but the fixed crop, board prior, rim geometry, and image center can all rescue frames where the obvious guess is wrong." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="320" y="480" width="320" height="220" as="geometry" />
        </mxCell>
        <mxCell id="cv_why_3" value="The needle is a thin dark radial spoke with edge structure, not just a line segment. Combining darkness, edge magnitude, radial and tangential alignment, hub continuity, tip extension, and a hot-zone rescue helps avoid false locks on dial markings." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="680" y="480" width="310" height="220" as="geometry" />
        </mxCell>
        <mxCell id="cv_why_4" value="The local sweep lets the firmware adjust for a few-pixel crop error without changing the overall geometry. Keeping the best-quality refined candidate and then collapsing to a consensus avoids letting one lucky anchor dominate the final read." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="1030" y="480" width="320" height="220" as="geometry" />
        </mxCell>
        <mxCell id="cv_why_5" value="The gate protects the board from unstable or ambiguous frames. When the best peak is too weak or too close to the runner-up, or the estimate jumps too much, the firmware holds the last stable value instead of publishing a noisy one." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="1390" y="480" width="300" height="220" as="geometry" />
        </mxCell>
        <mxCell id="cv_why_6" value="The gauge has a known 270° sweep from 135° and the calibration offset is measured, not learned. That makes angle-to-temperature a deterministic decode step once the needle angle is accepted." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="1730" y="470" width="290" height="220" as="geometry" />
        </mxCell>
        <mxCell id="cve1" style="endArrow=block;html=1;strokeColor=#000000;" parent="1" source="cv_tech_1" target="cv_tech_2" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cve2" style="endArrow=block;html=1;strokeColor=#000000;" parent="1" source="cv_tech_2" target="cv_tech_3" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cve3" style="endArrow=block;html=1;strokeColor=#000000;" parent="1" source="cv_tech_3" target="cv_tech_4" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cve4" style="endArrow=block;html=1;strokeColor=#000000;" parent="1" source="cv_tech_4" target="cv_tech_5" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cve5" style="endArrow=block;html=1;strokeColor=#000000;" parent="1" source="cv_tech_5" target="cv_tech_6" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cvw2" style="dashed=1;endArrow=none;html=1;strokeColor=#d79b00;" parent="1" source="kAxTJiGilQFAcQdgw8WS-3" target="cv_why_2" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cvw3" style="dashed=1;endArrow=none;html=1;strokeColor=#d79b00;" parent="1" source="kAxTJiGilQFAcQdgw8WS-5" target="cv_why_3" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cvw4" style="dashed=1;endArrow=none;html=1;strokeColor=#d79b00;" parent="1" target="cv_why_4" edge="1">
          <mxGeometry relative="1" as="geometry">
