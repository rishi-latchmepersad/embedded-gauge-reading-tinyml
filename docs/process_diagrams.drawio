        <mxCell id="V077Ls7bwzFt84BWvUJ_-1" value="Current Live AI Cascade Process Steps" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontStyle=1;fontSize=16;" parent="1" vertex="1">
          <mxGeometry y="60" width="350" height="30" as="geometry" />
        </mxCell>
        <mxCell id="LBQWEnL1_VHaJIz2CVFE-1" value="&lt;img src=&quot;data:image/svg+xml;base64,&quot; alt=&quot;Image preview&quot;&gt;" style="text;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1430" y="310" width="30" height="40" as="geometry" />
        </mxCell>
        <mxCell id="LBQWEnL1_VHaJIz2CVFE-3" value="&lt;img src=&quot;data:image/svg+xml;base64,&quot; alt=&quot;Image preview&quot;&gt;" style="text;whiteSpace=wrap;html=1;" vertex="1" parent="1">
