        <mxCell id="V077Ls7bwzFt84BWvUJ_-1" value="Current AI Cascade Process Steps" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontStyle=1;fontSize=16;" parent="1" vertex="1">
          <mxGeometry y="60" width="350" height="30" as="geometry" />
        </mxCell>
        <mxCell id="SH4CUb0vDkVNlqwSd1lD-1" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;editableCssRules=.*;image=data:image/svg+xml,;" parent="1" vertex="1">
          <mxGeometry x="1762.5" y="319" width="115" height="115" as="geometry" />
