<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/28.1.2 Chrome/138.0.7204.243 Electron/37.4.0 Safari/537.36" version="28.1.2" pages="2">
  <diagram id="6fHF2__YJ60N_B--ARtN" name="AI_Process">
    <mxGraphModel dx="964" dy="674" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="cnn_title_why" value="Why each step is performed" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontStyle=1;fontSize=16;" parent="1" vertex="1">
          <mxGeometry y="680" width="360" height="30" as="geometry" />
        </mxCell>
        <mxCell id="cnn_tech_1" value="The IMX335 image sensor captures a 224x224 color frame (YUV422)&lt;br&gt;- Manual exposure used (AEC disabled)&lt;br&gt;- The brightness is seeded from last accepted brightness value&lt;br&gt;  or 2/3-range fraction on first boot" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#dae8fc;strokeColor=#6c8ebf;image=process_diagrams_assets/cnn_01_capture.svg;imageAlign=right;imageVerticalAlign=middle;imageWidth=48;imageHeight=48;spacingRight=58;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="40" y="90" width="270" height="170" as="geometry" />
        </mxCell>
        <mxCell id="cnn_tech_2" value="A brightness gate is applied before inference&lt;br&gt;- Measure mean/min/max luma over the full frame or canonical crop&lt;br&gt;- Reject if the frame is too dark or too bright&lt;br&gt;- Nudge exposure ×2 or ÷2, and retry up to 16 attempts" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;image=process_diagrams_assets/cnn_02_brightness.svg;imageAlign=right;imageVerticalAlign=middle;imageWidth=48;imageHeight=48;spacingRight=58;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="350" y="90" width="280" height="170" as="geometry" />
        </mxCell>
        <mxCell id="cnn_tech_3" value="A compact OBB localizer finds the gauge face&lt;br&gt;- Input: full 224x224 color frame&lt;br&gt;- Output: oriented box (cx, cy, w, h, cos, sin) for pose normalization" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;image=process_diagrams_assets/cnn_03_obb_localizer.svg;imageAlign=right;imageVerticalAlign=middle;imageWidth=48;imageHeight=48;spacingRight=58;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="670" y="90" width="300" height="170" as="geometry" />
        </mxCell>
        <mxCell id="cnn_tech_4" value="The OBB is validated and used to extract the canonical crop for the needle model&lt;br&gt;- Check minimum size, angle, and in-bounds coordinates&lt;br&gt;- Expand slightly and clamp/rotate into the trained orientation&lt;br&gt;- Keep the OBB path available for diagnostics and fallback" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#fff2cc;strokeColor=#d6b656;image=process_diagrams_assets/cnn_04_crop_selection.svg;imageAlign=right;imageVerticalAlign=middle;imageWidth=48;imageHeight=48;spacingRight=58;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1010" y="90" width="290" height="170" as="geometry" />
        </mxCell>
        <mxCell id="cnn_tech_5" value="A compact tip-focus UNet reads the needle geometry&lt;br&gt;- Input: normalized gauge-face crop from the OBB path&lt;br&gt;- Output: center and tip heatmaps for angle estimation" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#d5e8d4;strokeColor=#82b366;image=process_diagrams_assets/cnn_05_geometry_keypoints.svg;imageAlign=right;imageVerticalAlign=middle;imageWidth=48;imageHeight=48;spacingRight=58;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1340" y="90" width="300" height="170" as="geometry" />
        </mxCell>
        <mxCell id="cnn_tech_6" value="Needle angle is converted to temperature output&lt;br&gt;- Convert center-tip geometry to angle&lt;br&gt;- Map angle to temperature with the calibrated sweep&lt;br&gt;- Log to SD card CSV and report via UART for debugging" style="rounded=1;whiteSpace=wrap;html=1;align=center;fillColor=#e1d5e7;strokeColor=#9673a6;image=process_diagrams_assets/cnn_06_angle_to_temperature.svg;imageAlign=right;imageVerticalAlign=middle;imageWidth=48;imageHeight=48;spacingRight=58;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="1680" y="90" width="280" height="170" as="geometry" />
        </mxCell>
        <mxCell id="cnn_why_1" value="Manual exposure gives consistent luma/brightness across captures.&amp;nbsp;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;AEC chases highlights (e.g. glare spots) and would destabilize the live AI input&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Cached seed means no brightness search delay after the first capture.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="40" y="480" width="270" height="190" as="geometry" />
        </mxCell>
        <mxCell id="cnn_why_2" value="The quality gate keeps obviously bad frames away from the model. Underexposed frames lose needle contrast and overexposed frames blow out the dial face.&amp;nbsp;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Checking luma before the AI stages also helps catch glare and exposure drift early.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="350" y="480" width="280" height="190" as="geometry" />
        </mxCell>
        <mxCell id="cnn_why_3" value="The OBB localizer normalizes gauge pose before the tip-focus UNet runs. That lets us handle rotated board captures and moving cameras without relying on a fixed crop.&lt;br&gt;&lt;br&gt;The downstream model sees a more consistent dial orientation, which is easier to train and more stable to deploy." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="670" y="480" width="300" height="190" as="geometry" />
        </mxCell>
        <mxCell id="cnn_why_4" value="The crop step turns the oriented box into the canonical OBB crop family the model was trained on. That keeps the input geometry stable even when the camera or gauge shifts in the field.&lt;br&gt;&lt;br&gt;We still keep the raw OBB path for telemetry and fallback logic." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="1010" y="480" width="290" height="190" as="geometry" />
        </mxCell>
        <mxCell id="cnn_why_5" value="A compact tip-focus UNet is a better fit for this gauge than a heavier detector head. Predicting center and tip heatmaps gives us the geometry we need for angle recovery without overcomplicating the board deployment.&lt;br&gt;&lt;br&gt;The heatmap formulation is also easier to quantify, export, and validate on embedded targets." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="1340" y="480" width="300" height="190" as="geometry" />
        </mxCell>
        <mxCell id="cnn_why_6" value="The final step is deterministic: once we know the needle angle, firmware maps that angle to temperature with the calibrated sweep.&lt;br&gt;&lt;br&gt;Logging every inference to SD card keeps us honest during validation and gives us clean data for future retraining." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="1680" y="480" width="280" height="190" as="geometry" />
        </mxCell>
        <mxCell id="cnn_e1" style="endArrow=block;html=1;strokeColor=#000000;" parent="1" source="cnn_tech_1" target="cnn_tech_2" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cnn_e2" style="endArrow=block;html=1;strokeColor=#000000;" parent="1" source="cnn_tech_2" target="cnn_tech_3" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cnn_e3" style="endArrow=block;html=1;strokeColor=#000000;" parent="1" source="cnn_tech_3" target="cnn_tech_4" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cnn_e4" style="endArrow=block;html=1;strokeColor=#000000;" parent="1" source="cnn_tech_4" target="cnn_tech_5" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cnn_e5" style="endArrow=block;html=1;strokeColor=#000000;" parent="1" source="cnn_tech_5" target="cnn_tech_6" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cnn_w1" style="dashed=1;endArrow=none;html=1;strokeColor=#d79b00;" parent="1" source="zElmDHNvidVek9H3AHMp-1" target="cnn_why_1" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cnn_w2" style="dashed=1;endArrow=none;html=1;strokeColor=#d79b00;" parent="1" source="zElmDHNvidVek9H3AHMp-3" target="cnn_why_2" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cnn_w3" style="dashed=1;endArrow=none;html=1;strokeColor=#d79b00;" parent="1" source="zElmDHNvidVek9H3AHMp-5" target="cnn_why_3" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cnn_w4" style="dashed=1;endArrow=none;html=1;strokeColor=#d79b00;" parent="1" source="zElmDHNvidVek9H3AHMp-7" target="cnn_why_4" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cnn_w5" style="dashed=1;endArrow=none;html=1;strokeColor=#d79b00;" parent="1" target="cnn_why_5" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1490" y="436" as="sourcePoint" />
