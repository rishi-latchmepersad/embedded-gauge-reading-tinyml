          </mxGeometry>
        </mxCell>
        <mxCell id="zElmDHNvidVek9H3AHMp-1" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;editableCssRules=.*;image=data:image/svg+xml,;" parent="1" vertex="1">
          <mxGeometry x="117.5" y="320" width="115" height="115" as="geometry" />
