        <mxCell id="pod3" value="Camera Pod #3&#xa;- Camera + MCU&#xa;- Battery + Solar&#xa;- On-device classical baseline + CNN cascade&#xa;- LoRaWAN radio" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fillColor=#cce5ff;strokeColor=#36393d;" parent="site_container" vertex="1">
